    {
      "id": "6a3f5de0-d213-4640-8f6c-12a0225bb3fe",
      "name": "Build Ledger Insert (Live)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2240, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const n = $('Normalize Signal').first().json;\nconst k = $('Kelly Gate (Live)').first().json.verdict;\nconst o = $input.first().json;\nconst eq = $('Fetch Equity (Live)').first().json.equity;\nconst esc = (s) => s == null ? null : String(s).replace(/'/g, \"''\");\nconst num = (v) => (v === null || v === undefined || v === '' || isNaN(Number(v))) ? 'NULL' : Number(v);\nconst str = (v) => (v == null || v === '') ? 'NULL' : \"'\" + esc(v) + \"'\";\nconst uuid = (v) => (v == null || v === '') ? 'NULL' : \"'\" + esc(v) + \"'::uuid\";\nconst meta = JSON.stringify(k || {}).split('$qet$').join('');\nconst sql = 'INSERT INTO public.trade_ledger (user_id, portfolio_id, signal_id, strategy, mode, symbol, side, qty, confidence, signal_time, intended_entry, intended_stop, intended_target, risk_amount, risk_pct_applied, sizing_meta, equity_at_entry, entry_order_id, entry_fill_price, entry_fill_time) VALUES (' + uuid(n.user_id) + ', ' + uuid(n.portfolio_id) + ', ' + uuid(n.signal_id) + ', ' + str(n.strategy) + ', ' + str(n.MODE) + ', ' + str(n.symbol) + ', ' + str(n.side) + ', ' + num(k.qty) + ', ' + num(n.confidence) + ', now(), ' + num(n.entry) + ', ' + num(n.stop) + ', ' + (n.target > 0 ? num(n.target) : 'NULL') + ', ' + num(k.risk_dollars) + ', ' + num(k.risk_pct) + ', $qet$' + meta + '$qet$::jsonb, ' + num(eq) + ', ' + str(o.id) + ', ' + num(o.filled_avg_price) + ', ' + (o.filled_at ? \"'\" + esc(o.filled_at) + \"'::timestamptz\" : 'NULL') + ') RETURNING id';\nreturn [{ json: { sql: sql } }];"
      }
    },
    {
      "id": "59461d4f-93b0-4967-8058-b972ea53c273",
