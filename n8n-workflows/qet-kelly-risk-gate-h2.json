    {
      "id": "999a1c50-11f3-4ac1-b39c-6909da963189",
      "name": "Prepare Audit Entry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2912, 480],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const n = $('Normalize Signal').first().json;\nconst item = $input.first().json;\nconst esc = (s) => s == null ? '' : String(s).replace(/'/g, \"''\");\nconst mode = n.MODE === 'live' ? 'live' : 'paper';\nconst decision = item.decision || 'rejected';\nconst reason = item.reason || 'unspecified';\nconst raw = JSON.stringify({ signal: n, context: item }).split('$qet$').join('');\nconst sql = \"INSERT INTO public.audit_log (user_id, workflow_name, execution_id, mode, decision, reason, signal_id, raw) VALUES (\" + ((n.user_id == null || n.user_id === '') ? 'NULL' : \"'\" + esc(n.user_id) + \"'::uuid\") + \", 'qet-kelly-risk-gate', '\" + esc($execution.id) + \"', '\" + mode + \"', '\" + esc(decision) + \"', '\" + esc(reason) + \"', \" + ((n.signal_id == null || n.signal_id === '') ? 'NULL' : \"'\" + esc(n.signal_id) + \"'::uuid\") + ', $qet$' + raw + '$qet$::jsonb)';\nreturn [{ json: { decision: decision, reason: reason, sql: sql } }];"
      }
    },
