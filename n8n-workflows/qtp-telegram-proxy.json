          "appendAttribution": false
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 1000,
      "onError": "continueRegularOutput",
      "webhookId": "79a0bdff-8f5d-4037-9cc7-44e652a9e395"
    },
