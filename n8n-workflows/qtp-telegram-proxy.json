      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// QTP Telegram Proxy v1.0 (2026-07-10) — holds the Telegram credential so legacy\n// Code-node workflows (TSM etc.) never embed the bot token. Token-gated.\nconst b = ($input.first().json.body) || {};\nconst TOKEN = '2679400ed5f501a97697e39257b1ea7904b6c5884f915d25';\nif (String(b.token || '') !== TOKEN) { throw new Error('QTP_TG_PROXY_FORBIDDEN'); }\nconst chatId = String(b.chat_id || '');\nconst text = String(b.text || '');\nif (!chatId || !text) { throw new Error('QTP_TG_PROXY_MISSING_FIELDS'); }\nreturn [{ json: { chat_id: chatId, text: text.slice(0, 4000) } }];"
      }
    },
    {
      "id": "0e8d9af8-e6a2-4c12-aa45-95a0a74256dd",
      "name": "Send Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        448,
        0
      ],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $json.chat_id }}",
        "text": "={{ $json.text }}",
        "additionalFields": {
